# DeepSeek API Key — 从 platform.deepseek.com 获取（只填这里，绝不提交到 Git）
DEEPSEEK_API_KEY="sk-5cfdc76f1db54ce39353693fbec5a922"

# 管理员密钥 — 用于手动给用户增加积分，设置一个复杂的随机字符串
ADMIN_KEY=qeucnfhkgsie_dahicnm_abc123xyz789

# 允许访问的前端域名（生产环境填你的域名，多个用逗号分隔）
# 开发环境不需要填，任何 localhost 都会被允许
ALLOWED_ORIGINS=https://yourdomain.com

# 服务器端口（默认 3000）
PORT=3000

# 运行环境（development 开发 / production 生产）
NODE_ENV=development
